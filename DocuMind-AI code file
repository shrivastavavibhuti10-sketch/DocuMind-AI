def process_pdf(pdf_file):
    global pdf_indexed
    text = extract_text_from_pdf(pdf_file.name)
    chunks = chunk_text(text)
    build_vector_store(chunks)
    pdf_indexed = True
    return f"✅ PDF indexed! {len(chunks)} chunks ready!"

def answer_question(question, history):
    if not pdf_indexed:
        history.append(("", "⚠️ Please upload and index a PDF first!"))
        return history
    if not question.strip():
        return history
    try:
        context = retrieve(question, top_k=4)
        answer = ask_groq(question, context)
        history.append((question, answer))
    except Exception as e:
        history.append((question, f"❌ Error: {str(e)}"))
    return history

def solve_math(problem, history):
    if not problem.strip():
        return history
    try:
        prompt = f"""You are an expert math teacher. Solve this problem step by step.

Problem: {problem}

Instructions:
- Show every step clearly
- Explain what you are doing at each step
- Give the final answer at the end
- Use simple language
"""
        response = client.chat.completions.create(
            model="llama-3.3-70b-versatile",
            messages=[{"role": "user", "content": prompt}],
            max_tokens=2048
        )
        answer = response.choices[0].message.content
        history.append((problem, answer))
    except Exception as e:
        history.append((problem, f"❌ Error: {str(e)}"))
    return history

